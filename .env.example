# Application
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://tsndoni:tsndoni@postgres:5432/tsndoni

# Admin session (JWT)
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# File storage (local disk on server)
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=20

# Email (optional)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@tsndoni.ru

# Analytics (Yandex.Metrica — loads only after cookie consent)
YANDEX_METRICA_ID=

# Public site URL (absolute links in Telegram and webhook registration)
PUBLIC_SITE_URL=http://localhost:8080

# --- Bot 1: Publish (сайт/админка → чат СНТ) ---
# Добавьте бота в чат СНТ и выдайте право отправлять сообщения.
TELEGRAM_PUBLISH_ENABLED=false
TELEGRAM_PUBLISH_BOT_TOKEN=
TELEGRAM_PUBLISH_CHAT_ID=
# Публичная ссылка-приглашение в чат СНТ (кнопка на сайте)
TELEGRAM_SUBSCRIBE_URL=

# --- Bot 2: Inlet (Telegram → сайт, раздел «Важно!») ---
# Отдельный бот. Только whitelist Telegram user ID может публиковать.
TELEGRAM_INLET_ENABLED=false
TELEGRAM_INLET_BOT_TOKEN=
# Случайная строка для URL webhook и заголовка X-Telegram-Bot-Api-Secret-Token
TELEGRAM_INLET_WEBHOOK_SECRET=
# Telegram user ID через запятую (узнать: /whoami у inlet-бота)
TELEGRAM_INLET_ALLOWED_USER_IDS=
# Ссылка на бота для правления, например https://t.me/tsndoni_inlet_bot
TELEGRAM_INLET_BOT_URL=
# true = long polling (локальная разработка без HTTPS), false = webhook (production)
TELEGRAM_INLET_USE_POLLING=false
